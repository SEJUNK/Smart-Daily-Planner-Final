// === firestore.rules ===
// Firestore Security Rules for Smart Daily Planner
//
// Deploy:  firebase deploy --only firestore:rules
// Test:    firebase emulators:start --only firestore
//
// Architecture:
//   - All user data (tasks, notes, event_log) is scoped by user_id field.
//   - Auth is handled at the API layer (FastAPI + JWT cookie).
//   - These rules are the last line of defence if API auth is bypassed.
//   - The server-side service account has admin access (bypasses these rules).

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Deny all by default ──────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ── Tasks ────────────────────────────────────────────────────────────────
    // Each task document must have a user_id field matching the authenticated user.
    match /tasks/{taskId} {
      allow read:   if request.auth != null && resource.data.user_id == request.auth.token.email;
      allow create: if request.auth != null
                    && request.resource.data.user_id == request.auth.token.email
                    && request.resource.data.title is string
                    && request.resource.data.title.size() > 0
                    && request.resource.data.title.size() <= 500;
      allow update: if request.auth != null
                    && resource.data.user_id == request.auth.token.email
                    // Prevent changing user_id on existing documents
                    && (!request.resource.data.keys().hasAny(['user_id'])
                        || request.resource.data.user_id == resource.data.user_id);
      allow delete: if request.auth != null && resource.data.user_id == request.auth.token.email;
    }

    // ── Notes ────────────────────────────────────────────────────────────────
    match /notes/{noteId} {
      allow read:   if request.auth != null && resource.data.user_id == request.auth.token.email;
      allow create: if request.auth != null
                    && request.resource.data.user_id == request.auth.token.email
                    && request.resource.data.title is string
                    && request.resource.data.content is string
                    && request.resource.data.content.size() <= 50000;
      allow update: if request.auth != null
                    && resource.data.user_id == request.auth.token.email
                    && (!request.resource.data.keys().hasAny(['user_id'])
                        || request.resource.data.user_id == resource.data.user_id);
      allow delete: if request.auth != null && resource.data.user_id == request.auth.token.email;
    }

    // ── Event log (undo history) ──────────────────────────────────────────────
    match /event_log/{eventId} {
      allow read:   if request.auth != null && resource.data.user_id == request.auth.token.email;
      allow create: if request.auth != null
                    && request.resource.data.user_id == request.auth.token.email;
      allow delete: if request.auth != null && resource.data.user_id == request.auth.token.email;
      // Event log entries are immutable once written — no updates allowed
      allow update: if false;
    }

    // ── User profiles ────────────────────────────────────────────────────────
    match /users/{userId} {
      // Users can only read/write their own profile
      allow read, write: if request.auth != null && request.auth.token.email == userId;
    }

    // ── Retros (read-only to owner) ───────────────────────────────────────────
    match /retros/{retroId} {
      allow read:   if request.auth != null && resource.data.user_id == request.auth.token.email;
      allow create: if request.auth != null
                    && request.resource.data.user_id == request.auth.token.email;
      allow update, delete: if request.auth != null
                    && resource.data.user_id == request.auth.token.email;
    }
  }
}
